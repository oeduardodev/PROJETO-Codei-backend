{
  "extends": "adonis-preset-ts/tsconfig.json",
  "include": [
    "**/*"
  ],
  "exclude": [
    "node_modules",
    "build"
  ],
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "baseUrl": ".",
    "paths": {
      "app/*": [
        "app/*"
      ],
      "App/*": [
        "app/*"
      ]
    },
    "outDir": "build",
    "rootDir": ".",
    "strict": true,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": [
      "@adonisjs/core",
      "@adonisjs/lucid",
      "@adonisjs/auth",
      "@adonisjs/repl",
      "minimatch"
    ]
  }
}


